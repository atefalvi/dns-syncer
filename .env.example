# DNS Syncer environment overrides (all optional).
# Config, secrets, and the Cloudflare token are managed in the web UI, not here.

# Force development mode (use ./.local instead of /etc, /var). Unset in production.
# DNS_SYNCER_DEV=1

# Override the whole data directory (config + state + logs in one place).
# DNS_SYNCER_HOME=/path/to/data

# Path to the static frontend (set by the systemd unit in production).
# DNS_SYNCER_FRONTEND=/opt/dns-syncer/frontend
